# Local proxy port. Claude Code can use http://127.0.0.1:17860/anthropic as ANTHROPIC_BASE_URL.
DEEPSEEK_MONITOR_PORT=17860

# Optional fallback key for the local proxy. Prefer passing a newly-created DeepSeek key from Claude Code as ANTHROPIC_AUTH_TOKEN.
# Never commit real keys. Existing masked keys in the DeepSeek console cannot be recovered.
DEEPSEEK_API_KEY=

# Defaults are usually enough.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Optional local data directory. Defaults to ~/.deepseek-monitor-assistant.
# Existing ~/.deepseek-cache-doctor data is reused automatically for compatibility.
DEEPSEEK_MONITOR_DATA_DIR=
